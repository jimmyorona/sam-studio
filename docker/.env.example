# Copy to .env and adjust. Consumed by `docker run --env-file` or compose.

# Port the Express server listens on inside the container.
PORT=3001

# Ollama endpoint the app uses. Ollama is bundled in the container, so the default
# points at it on localhost. Set this to an external Ollama (e.g. a GPU instance
# in the VPC) to bypass the bundled one — the entrypoint then won't start it.
OLLAMA_URL=http://localhost:11434

# Optional: pull an ADDITIONAL model at container startup (llama3.1:8b is already
# baked in). Example: llama3.2:3b
# OLLAMA_PULL=llama3.2:3b
